    private async Task SaveRig()
    {
        if (_currentRig?.MetaInfo == null)
        {
            Snackbar.Add("Rig metadata is missing.", Severity.Error);
            return;
        }

        if (_currentRig.IsFixedPlatform)
        {
            if (_selectedField == null || _selectedCluster?.MetaInfo == null)
            {
                Snackbar.Add("A fixed platform rig must be associated with a field and a cluster.", Severity.Warning);
                return;
            }

            _currentRig.ClusterID = _selectedCluster.MetaInfo.ID;
        }
        else
        {
            _selectedField = null;
            _selectedCluster = null;
            _currentRig.ClusterID = null;
        }

        if (_currentRig.CreationDate == null)
        {
            _currentRig.CreationDate = DateTimeOffset.UtcNow;
        }
        _currentRig.LastModificationDate = DateTimeOffset.UtcNow;

        try
        {
            HttpStatusCode statusCode = _isNewRig
                ? await RigApiClient.CreateRigAsync(_currentRig)
                : await RigApiClient.UpdateRigAsync(_currentRig);

            if (statusCode == HttpStatusCode.OK)
            {
                Snackbar.Add("Rig saved.", Severity.Success);
                BackToList();
            }
            else
            {
                Snackbar.Add($"Save failed: {(int)statusCode} {statusCode}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save rig {RigId}", _currentRig.MetaInfo.ID);
            Snackbar.Add("Failed to save rig.", Severity.Error);
        }
    }

    private void BackToList() => NavigationManager.NavigateTo(BuildPageUri("Rig"));

    private static IEnumerable<RigTreeNode> FlattenNodes(RigTreeNode node)
    {
        yield return node;
        foreach (RigTreeNode child in node.Children)
        {
            foreach (RigTreeNode descendant in FlattenNodes(child))
            {
                yield return descendant;
            }
        }
    }

    private static bool NodeMatchesFilter(RigTreeNode node, string? filter)
    {
        string query = NormalizeSearchText(filter);
        if (string.IsNullOrWhiteSpace(query))
        {
            return true;
        }

        return NormalizeSearchText(node.Label).Contains(query, StringComparison.Ordinal)
            || NormalizeSearchText(node.Key).Contains(query, StringComparison.Ordinal)
            || NormalizeSearchText(node.ValueType.Name).Contains(query, StringComparison.Ordinal);
    }

    private static string NormalizeSearchText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).Select(char.ToLowerInvariant).ToArray());
    }

    private void ExpandPath(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        string current = key!;
        while (!string.IsNullOrWhiteSpace(current))
        {
            _expandedTreeKeys.Add(current);
            int listIndex = current.LastIndexOf('[');
            int propertyIndex = current.LastIndexOf('.');
            int cutIndex = Math.Max(listIndex, propertyIndex);
            if (cutIndex <= 0)
            {
                break;
            }

            current = current.Substring(0, cutIndex);
        }

        _expandedTreeKeys.Add("Rig");
    }

    private IEnumerable<RigTreeNode> BuildVisibleTreeNodes(RigTreeNode root)
    {
        if (_hideUninstantiatedNodes && !root.Exists && !root.IsRoot)
        {
            yield break;
        }

        yield return root;

        if (!IsExpanded(root.Key))
        {
            yield break;
        }

        foreach (RigTreeNode child in root.Children)
        {
            if (_hideUninstantiatedNodes && !child.Exists && !child.IsRoot)
            {
                continue;
            }

            foreach (RigTreeNode descendant in BuildVisibleTreeNodes(child))
            {
                yield return descendant;
            }
        }
    }

    private string GetNodeButtonClass(RigTreeNode node)
    {
        if (node.Exists)
        {
            return "rig-tree-node-existing";
        }

        if (node.CanCreate || node.CanAddItem)
        {
            return "rig-tree-node-missing";
        }

        return "rig-tree-node-disabled";
    }

    private void UpdateCurrentRigDepthReferenceSource() => DataUtils.ApplyRigClusterReferenceValues(_currentRig, CurrentRigCluster);

    private string BuildPageUri(string relativePath) =>
        new Uri(new Uri(NavigationManager.BaseUri), relativePath).ToString();
