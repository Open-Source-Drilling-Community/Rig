@namespace NORCE.Drilling.Rig.WebPages.Components.RigMastEditors

<RigComplexPropertyEditor Title="Crown Block"
                          Value="RigMast.HoistingSystem?.CrownBlock"
                          ValueChanged="@(value => SetCrownBlock(value))"
                          ModelType="@typeof(CrownBlock)" />

@code {
    [Parameter, EditorRequired] public RigMast RigMast { get; set; } = default!;

    private void SetCrownBlock(object? value)
    {
        RigMast.HoistingSystem ??= new HoistingSystem();
        RigMast.HoistingSystem.CrownBlock = (CrownBlock?)value;
    }
}

