@namespace WebApp.Components.RigMastEditors

<MudExpansionPanels MultiExpansion="true">
    <RigMastGeneralEditor RigMast="RigMast" />

    <MudExpansionPanel Text="Hoisting System" Expanded="true">
        <MudStack Spacing="2">
            <RigMastDerrickEditor RigMast="RigMast" />
            <RigMastDrawworksEditor RigMast="RigMast" />
            <RigMastCrownBlockEditor RigMast="RigMast" />
            <RigMastTravellingBlockEditor RigMast="RigMast" />
            <RigMastDrillLineEditor RigMast="RigMast" />
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Rotary And Drive" Expanded="false">
        <MudStack Spacing="2">
            <RigMastTopDriveEditor RigMast="RigMast" />
            <RigMastKellyEditor RigMast="RigMast" />
            <RigMastRotaryTableEditor RigMast="RigMast" />
            <RigMastTorqueTurnSubEditor RigMast="RigMast" />
            <RigMastCasingDriveSystemEditor RigMast="RigMast" />
            <RigMastCoilDriveSystemEditor RigMast="RigMast" />
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Pipe Handling" Expanded="false">
        <MudStack Spacing="2">
            <RigMastCatWalkEditor RigMast="RigMast" />
            <RigMastPipeRackEditor RigMast="RigMast" />
            <RigMastIronRoughneckEditor RigMast="RigMast" />
            <RigMastCasingTongsEditor RigMast="RigMast" />
            <RigMastCasingRunningToolEditor RigMast="RigMast" />
            <RigMastSlipsEditor RigMast="RigMast" />
        </MudStack>
    </MudExpansionPanel>

    <MudExpansionPanel Text="Fluid Circulation" Expanded="false">
        <MudStack Spacing="2">
            <RigMastStandPipeEditor RigMast="RigMast" />
            <RigMastStandPipeManifoldEditor RigMast="RigMast" />
            <RigMastRotaryHoseEditor RigMast="RigMast" />
            <RigMastChokeManifoldEditor RigMast="RigMast" />
            <RigMastRigChokeListEditor RigMast="RigMast" />
        </MudStack>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    [Parameter, EditorRequired] public RigMast RigMast { get; set; } = default!;
}
