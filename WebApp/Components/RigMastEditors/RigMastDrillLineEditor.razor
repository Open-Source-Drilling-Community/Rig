@namespace WebApp.Components.RigMastEditors

<RigComplexPropertyEditor Title="Drill Line"
                          Value="RigMast.HoistingSystem?.DrillLine"
                          ValueChanged="@(value => SetDrillLine(value))"
                          ModelType="@typeof(DrillLine)" />

@code {
    [Parameter, EditorRequired] public RigMast RigMast { get; set; } = default!;

    private void SetDrillLine(object? value)
    {
        RigMast.HoistingSystem ??= new HoistingSystem();
        RigMast.HoistingSystem.DrillLine = (DrillLine?)value;
    }
}
