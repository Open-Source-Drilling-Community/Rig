@namespace NORCE.Drilling.Rig.WebPages.Components.RigMastEditors

<MudExpansionPanel Text="General" Expanded="true">
    <MudPaper Class="pa-3" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="RigMast.Name" Label="Name" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="RigMast.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudExpansionPanel>

@code {
    [Parameter, EditorRequired] public RigMast RigMast { get; set; } = default!;
}

