@namespace NORCE.Drilling.Rig.WebPages.Components.RigEditors

<MudExpansionPanel Text="Main Rig Mast" Expanded="false">
    <MudPaper Class="pa-3" Outlined="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Main Rig Mast</MudText>
        <RigMastEditor RigMast="Rig.MainRigMast" />
    </MudPaper>
</MudExpansionPanel>

@code {
    [Parameter, EditorRequired] public Rig Rig { get; set; } = default!;

    protected override void OnParametersSet()
    {
        Rig.MainRigMast ??= new RigMast();
    }
}

