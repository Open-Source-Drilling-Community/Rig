<MudExpansionPanel Text="@Title" Expanded="false">
    <MudPaper Class="pa-3" Outlined="true">
        <QuantityField Value="Value" ValueChanged="OnValueChanged" Quantity="@Quantity" Label="@Title" />
    </MudPaper>
</MudExpansionPanel>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Quantity { get; set; } = "Dimensionless";
    [Parameter] public double? Value { get; set; }
    [Parameter] public EventCallback<double?> ValueChanged { get; set; }

    private async Task OnValueChanged(double? value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }
}
